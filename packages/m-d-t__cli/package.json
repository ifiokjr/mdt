	"type": "module",
	"description": "CLI for managing markdown templates across your project — keep docs, READMEs, and source comments in sync",
	"keywords": [
		"markdown",
		"templates",
		"cli",
		"docs",
		"mcp"
	],
	"homepage": "https://github.com/ifiokjr/mdt",
	"bugs": {
		"url": "https://github.com/ifiokjr/mdt/issues"
	},
	"license": "Unlicense",
	"repository": "https://github.com/ifiokjr/mdt/tree/main/packages/m-d-t__cli",
	"bin": {
		"mdt": "bin/mdt.js"
	},
	"files": [
		"bin",
		"README.md"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"optionalDependencies": {
		"@m-d-t/cli-darwin-arm64": "^0.8.0",
		"@m-d-t/cli-darwin-x64": "^0.8.0",
		"@m-d-t/cli-linux-arm64-gnu": "^0.8.0",
		"@m-d-t/cli-linux-arm64-musl": "^0.8.0",
