		"@m-d-t/cli-linux-x64-musl": "^0.8.0",
		"@m-d-t/cli-win32-arm64-msvc": "^0.8.0",
		"@m-d-t/cli-win32-x64-msvc": "^0.8.0"
	},
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "pnpm --dir ../.. build",
		"prepack": "pnpm --dir ../.. build",
		"prepublishOnly": "pnpm --dir ../.. build"
	}
}
