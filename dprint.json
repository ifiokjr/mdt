{
	"incremental": true,
	"indentWidth": 2,
	"useTabs": true,
	"exec": {
		"commands": [
			{
				"command": "rustup run nightly rustfmt --unstable-features --edition 2024",
				"exts": ["rs"]
			},
			{
				"command": "nixfmt",
				"exts": ["nix"]
			},
			{
				"command": "taplo format --config .taplo.toml --stdin-filepath {{file_path}} -",
				"exts": ["toml"]
			},
			{
				"command": "shfmt --filename {{file_path}} -i 0",
				"exts": ["sh", "bash"]
			}
		]
	},
	"typescript": {
		"deno": true,
		"useTabs": true,
		"module.sortExportDeclarations": "caseInsensitive",
		"module.sortImportDeclarations": "caseInsensitive"
	},
	"json": {
		"deno": true,
		"useTabs": true
	},
	"markdown": {
		"deno": true,
		"textWrap": "never"
	},
	"excludes": [
		"**/dist",
		"docs/book",
		".devenv/**",
		"**/fixtures",
		"**/snapshots",
		"**/target",
		"**/node_modules",
		".bin/",
		".local-cache/",
		"**/pkg/"
	],
	"plugins": [
		"https://plugins.dprint.dev/typescript-0.96.1.wasm",
		"https://plugins.dprint.dev/json-0.21.3.wasm",
		"https://plugins.dprint.dev/markdown-0.22.1.wasm",
		"https://plugins.dprint.dev/exec-0.6.0.json@a054130d458f124f9b5c91484833828950723a5af3f8ff2bd1523bd47b83b364",
		"https://plugins.dprint.dev/g-plane/pretty_yaml-v0.6.0.wasm"
	]
}
