{
	"name": "@m-d-t/root",
	"private": true,
	"type": "module",
	"description": "Monorepo root for mdt npm packages",
	"license": "Unlicense",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ifiokjr/mdt.git"
	},
	"scripts": {
		"check": "tsgo -config tsconfig.json",
		"fmt": "oxfmt --write \"**/*.ts\"",
		"fmt:check": "oxfmt --check \"**/*.ts\"",
		"lint": "oxlint --type-aware .",
		"lint:syntax": "oxlint .",
		"build": "tsdown"
	},
	"devDependencies": {
		"@rslint/tsgo": "^0.6.4",
		"@types/node": "^26.1.0",
		"oxfmt": "^0.57.0",
		"oxlint": "^1.72.0",
		"oxlint-tsgolint": "^0.24.0",
		"tsdown": "^0.22.3",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vitest": "^4.1.9"
	},
	"engines": {
		"node": ">=24.0.0",
		"pnpm": ">=10"
	}
}
